# ============================================================
# SSO_HC - File cấu hình môi trường (EXAMPLE)
# Copy file này thành .env và điền giá trị thật trước khi chạy
# ============================================================

# --- Strava API ---
# Lấy tại: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here
STRAVA_CLUB_ID=your_club_id_here

# --- App URL (quan trọng cho Strava OAuth) ---
# Phải khớp chính xác với “Authorization Callback Domain” trong Strava App settings
# Docker / production : https://yourdomain.com
# Dev local          : http://localhost:8000
APP_URL=https://yourdomain.com

# --- Webhook ---
# Token xác minh Strava Webhook (có thể đặt tuỳ ý, dùng chuỗi ngẫu nhiên)
STRAVA_WEBHOOK_VERIFY_TOKEN=SSO_HC_VERIFY_TOKEN

# --- Tài khoản Admin mặc định ---
# Chỉ dùng cho lần khởi tạo CSDL đầu tiên - hãy đổi mật khẩu sau khi deploy
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=admin

# --- Cơ sở dữ liệu ---
# Docker : sqlite:////app/SSO_HC.db  (tương ứng volume mount ./SSO_HC.db:/app/SSO_HC.db)
# Local  : sqlite:///./SSO_HC.db     (chạy trực tiếp bằng run.bat)
DATABASE_URL=sqlite:////app/SSO_HC.db
