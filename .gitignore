# ==========================================
# SSO_HC - .gitignore
# ==========================================

# --- Python ---
.venv/
venv/
ENV/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# --- Database (không commit dữ liệu thật) ---
*.db
*.sqlite
*.sqlite3
data/

# --- Sensitive Configs ---
# .env chứa client_secret, mật khẩu → KHÔNG bao giờ commit
.env

# --- Uploads (ảnh do người dùng upload, không commit vào Git) ---
static/uploads/

# --- Docker override (cấu hình riêng khi dev local) ---
docker-compose.override.yml
docker-compose.local.yml

# --- Temp / Logs ---
*.log
excel_info.txt
docx_content.txt
.system_generated/

# --- Backup & Data cũ ---
old_and_backup/

# --- Dữ liệu lịch sử (GDPR / Bảo mật thông tin cá nhân) ---
Tong ket nam 2025/
Tong ket nam 2026/
test_output.xlsx

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# --- Scratch Debug Files ---
scratch/
